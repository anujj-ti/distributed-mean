# ─────────────────────────────────────────────────────────────────────────────
# Distributed Mean — Environment Variables
# Copy to .env and adjust for your environment.
# ─────────────────────────────────────────────────────────────────────────────

# API
PORT=3000

# Number of worker replicas (used by docker compose --scale or override)
WORKER_COUNT=4

# Redis (local: redis://redis:6379, cloud: redis://user:pass@host:port)
REDIS_URL=redis://redis:6379

# PostgreSQL (local: below, cloud: postgresql://user:pass@host:5432/db)
DATABASE_URL=postgresql://dm:dm@postgres:5432/dm
POSTGRES_USER=dm
POSTGRES_PASSWORD=dm
POSTGRES_DB=dm

# MinIO / S3 (local: below, cloud: change endpoint + real AWS creds)
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=distributed-mean
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1

# Worker config
API_URL=http://api:3000
# Simulate variable worker speeds (0 = no slowness, 0.5 = 0.5s per file processed)
WORKER_SLOWNESS=0
